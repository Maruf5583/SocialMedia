@model List<SocialMedia.Models.Group>
@{
    ViewData["Title"] = "Groups";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-people-fill"></i> My Groups
    </h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Create Group
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-people" style="font-size:3rem"></i>
        <p class="mt-3">You are not in any groups yet.</p>
        <a asp-action="Create" class="btn btn-primary mt-2">
            <i class="bi bi-plus-circle"></i> Create your first group
        </a>
    </div>
}

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var group in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center p-4">

                    @if (!string.IsNullOrEmpty(group.GroupPicture))
                    {
                        <img src="@group.GroupPicture"
                             class="rounded-circle mb-3"
                             style="width:75px;height:75px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-success text-white d-flex
                            align-items-center justify-content-center mx-auto mb-3"
                             style="width:75px;height:75px;font-size:1.8rem;">
                            <i class="bi bi-people-fill"></i>
                        </div>
                    }

                    <h6 class="fw-bold">@group.Name</h6>
                    <p class="text-muted small mb-2">
                        @(string.IsNullOrEmpty(group.Description)
                            ? "No description"
                            : group.Description.Length > 60
                                ? group.Description[..60] + "..."
                                : group.Description)
                    </p>
                    <span class="badge bg-secondary mb-3">
                        <i class="bi bi-people"></i> @group.Members.Count members
                    </span>

                    <div class="d-flex gap-2 justify-content-center">
                        <a asp-action="Chat" asp-route-id="@group.Id"
                               class="btn btn-success btn-sm">
                            <i class="bi bi-chat-fill"></i> Open Chat
                        </a>
                        <a asp-action="Details" asp-route-id="@group.Id"
                               class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-info-circle"></i> Details
                        </a>
                    </div>
                </div>
                <div class="card-footer text-muted small text-center">
                    Created by @group.CreatedBy.FullName
                </div>
            </div>
        </div>
    }
</div>