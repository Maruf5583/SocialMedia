@model SocialMedia.ViewModels.CreateGroupViewModel
@{
    ViewData["Title"] = "Create Group";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="bi bi-plus-circle"></i> Create New Group
                </h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post"
                      enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All"
                         class="alert alert-danger d-none" id="valSummary"></div>

                    <!-- Group Name -->
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">
                            Group Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control"
                               placeholder="e.g. Bestie Squad 🔥" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">
                            Description
                        </label>
                        <textarea asp-for="Description" class="form-control" rows="2"
                                  placeholder="What is this group about?"></textarea>
                    </div>

                    <!-- Group Picture -->
                    <div class="mb-4">
                        <label asp-for="GroupPictureFile" class="form-label fw-semibold">
                            Group Picture
                        </label>
                        <input asp-for="GroupPictureFile" type="file"
                               class="form-control" accept="image/*" />
                        <div class="form-text">Optional. Max 5MB.</div>
                    </div>

                    <!-- Select Friends -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Add Friends
                        </label>
                        @if (!Model.Friends.Any())
                        {
                            <div class="alert alert-info py-2">
                                <i class="bi bi-info-circle"></i>
                                You have no friends to add yet.
                                <a asp-controller="Home" asp-action="Index">Find friends</a>
                            </div>
                        }
                        else
                        {
                            <div class="border rounded p-2"
                                 style="max-height:280px;overflow-y:auto;">
                                @for (int i = 0; i < Model.Friends.Count; i++)
                                {
                                    var friend = Model.Friends[i];
                                    <div class="form-check d-flex align-items-center gap-2 p-2
                                        rounded hover-bg">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               name="SelectedFriendIds"
                                               value="@friend.UserId"
                                               id="friend_@friend.UserId" />

                                        @if (!string.IsNullOrEmpty(friend.Avatar))
                                        {
                                            <img src="@friend.Avatar"
                                                 class="rounded-circle"
                                                 style="width:36px;height:36px;object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <div class="rounded-circle bg-primary text-white
                                                d-flex align-items-center
                                                justify-content-center"
                                                 style="width:36px;height:36px;">
                                                @friend.FullName[0]
                                            </div>
                                        }

                                        <label class="form-check-label fw-semibold"
                                               for="friend_@friend.UserId">
                                            @friend.FullName
                                        </label>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Create Group
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>