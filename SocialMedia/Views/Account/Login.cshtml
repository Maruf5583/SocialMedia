@model SocialMedia.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login"; Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - SocialApp</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container">
        <div class="row justify-content-center mt-5">
            <div class="col-md-5">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h3 class="text-center text-primary fw-bold mb-1">
                            <i class="bi bi-people-fill"></i> SocialApp
                        </h3>
                        <p class="text-center text-muted mb-4">Sign in to your account</p>

                        <form asp-action="Login" method="post">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="All" class="alert alert-danger"></div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label fw-semibold"></label>
                                <input asp-for="Email" class="form-control"
                                       placeholder="Enter your email" />
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-semibold"></label>
                                <input asp-for="Password" class="form-control"
                                       placeholder="Enter your password" />
                            </div>

                            <div class="mb-4 form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label"></label>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 fw-semibold">
                                Login
                            </button>
                        </form>

                        <hr />
                        <p class="text-center mb-0">
                            Don't have an account?
                            <a asp-action="Register" class="text-primary fw-semibold">Register</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>