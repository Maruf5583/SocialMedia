@model SocialMedia.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<div class="row">
    <!-- Left Column - Profile Info -->
    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm">
            <div class="card-body p-4">

                <!-- Profile Header -->
                <div class="text-center mb-4">
                    @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                    {
                        <img src="@Model.ProfilePicture"
                             class="rounded-circle"
                             style="width:120px;height:120px;object-fit:cover;border:3px solid #0d6efd;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-primary text-white d-flex
                            align-items-center justify-content-center mx-auto"
                             style="width:120px;height:120px;font-size:3rem;">
                            @Model.FullName[0]
                        </div>
                    }
                    <h3 class="fw-bold mt-3 mb-1">@Model.FullName</h3>
                    <p class="text-muted mb-2">@(Model.Bio ?? "No bio yet")</p>
                    <div class="d-flex justify-content-center gap-3">
                        <span class="badge bg-secondary">
                            <i class="bi bi-people"></i> @Model.FriendsCount Friends
                        </span>
                        <span class="badge bg-secondary">
                            <i class="bi bi-newspaper"></i> @Model.PostsCount Posts
                        </span>
                    </div>
                </div>

                <!-- Action Buttons -->
                @if (!Model.IsOwnProfile)
                {
                    <div class="d-flex gap-2 justify-content-center mb-3">
                        @if (Model.IsFriend)
                        {
                            <a asp-controller="Chat" asp-action="Open"
                                   asp-route-userId="@Model.Id"
                                   class="btn btn-success btn-sm">
                                <i class="bi bi-chat-fill"></i> Message
                            </a>
                            <form asp-controller="Friend" asp-action="Unfriend" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="friendId" value="@Model.Id" />
                                <button class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-person-dash"></i> Unfriend
                                </button>
                            </form>
                        }
                        else if (Model.HasPendingRequest)
                        {
                            <form asp-controller="Friend" asp-action="CancelRequest" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="requestId" value="@Model.FriendRequestId" />
                                <button class="btn btn-secondary btn-sm">
                                    <i class="bi bi-x-circle"></i> Cancel
                                </button>
                            </form>
                        }
                        else if (Model.HasReceivedRequest)
                        {
                            <form asp-controller="Friend" asp-action="AcceptRequest" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="requestId" value="@Model.FriendRequestId" />
                                <button class="btn btn-primary btn-sm">
                                    <i class="bi bi-check-circle"></i> Accept
                                </button>
                            </form>
                            <form asp-controller="Friend" asp-action="RejectRequest" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="requestId" value="@Model.FriendRequestId" />
                                <button class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-x"></i> Reject
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-controller="Friend" asp-action="SendRequest" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="receiverId" value="@Model.Id" />
                                <button class="btn btn-primary btn-sm">
                                    <i class="bi bi-person-plus"></i> Add Friend
                                </button>
                            </form>
                        }
                    </div>
                }

                <!-- Edit Form (only own profile) -->
                @if (Model.IsOwnProfile)
                {
                    <hr />
                    <h6 class="fw-bold mb-3">Edit Profile</h6>
                    <form asp-action="EditProfile" method="post"
                          enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-semibold small"></label>
                            <input asp-for="FullName" class="form-control form-control-sm" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Bio" class="form-label fw-semibold small"></label>
                            <textarea asp-for="Bio" class="form-control form-control-sm" rows="3"
                                      placeholder="Tell people about yourself..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProfilePictureFile" class="form-label fw-semibold small">
                                Profile Picture
                            </label>
                            <input asp-for="ProfilePictureFile" type="file"
                                   class="form-control form-control-sm" accept="image/*" />
                            <div class="form-text small">Max 5MB. JPG, PNG, GIF, WEBP allowed.</div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-sm w-100">
                            <i class="bi bi-save"></i> Save Changes
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    <!-- Right Column - User Posts -->
    <div class="col-lg-8">
        <div class="card shadow-sm mb-3">
            <div class="card-body p-3">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-newspaper"></i> @Model.FullName's Posts
                </h5>
            </div>
        </div>

        <!-- Posts Feed -->
        <div id="postsFeed">
            @if (!Model.Posts.Any())
            {
                <div class="card shadow-sm">
                    <div class="card-body text-center text-muted py-5">
                        <i class="bi bi-newspaper" style="font-size:3rem"></i>
                        <p class="mt-3">No posts yet.</p>
                        @if (Model.IsOwnProfile)
                        {
                            <p class="small">Share your first post!</p>
                        }
                    </div>
                </div>
            }

            @foreach (var post in Model.Posts)
            {
                @await Html.PartialAsync("_PostCard", post)
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/microsoft-signalr@7.0.5/dist/browser/signalr.min.js"></script>
    <script src="~/js/reaction.js"></script>
    <script>
        // Initialize SignalR
        document.addEventListener('DOMContentLoaded', function() {
        initializeSignalR('/postHub', '@Model.CurrentUserId');
        });
    </script>
}