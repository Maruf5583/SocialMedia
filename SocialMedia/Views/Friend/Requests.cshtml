@model List<SocialMedia.Models.FriendRequest>
@{
    ViewData["Title"] = "Friend Requests";
}

<h4 class="fw-bold mb-4">
    <i class="bi bi-person-plus-fill"></i> Friend Requests
    @if (Model.Any())
    {
        <span class="badge bg-danger ms-2">@Model.Count</span>
    }
</h4>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-inbox" style="font-size:3rem"></i>
        <p class="mt-2">No pending friend requests.</p>
    </div>
}

<div class="row row-cols-1 row-cols-md-2 g-3">
    @foreach (var req in Model)
    {
        <div class="col">
            <div class="card shadow-sm">
                <div class="card-body d-flex align-items-center gap-3">
                    @if (!string.IsNullOrEmpty(req.Sender.ProfilePicture))
                    {
                        <img src="@req.Sender.ProfilePicture"
                             class="rounded-circle"
                             style="width:55px;height:55px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-primary text-white d-flex
                            align-items-center justify-content-center"
                             style="width:55px;height:55px;font-size:1.4rem;">
                            @req.Sender.FullName[0]
                        </div>
                    }

                    <div class="flex-grow-1">
                        <a asp-controller="Account" asp-action="Profile"
                               asp-route-id="@req.Sender.Id"
                               class="fw-bold text-decoration-none text-dark">
                            @req.Sender.FullName
                        </a>
                        <div class="text-muted small">
                            @req.CreatedAt.ToString("MMM dd, yyyy")
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <form asp-controller="Friend" asp-action="AcceptRequest" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" value="@req.Id" />
                            <button class="btn btn-primary btn-sm">
                                <i class="bi bi-check"></i> Accept
                            </button>
                        </form>
                        <form asp-controller="Friend" asp-action="RejectRequest" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" value="@req.Id" />
                            <button class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-x"></i> Reject
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>