@model SocialMedia.ViewModels.ChatViewModel
@{ ViewData["Title"] = $"Chat with {Model.FriendName}"; }

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm" style="height:85vh; display:flex; flex-direction:column;">

            <!-- Chat Header -->
<div class="card-header bg-primary text-white d-flex align-items-center gap-3">
    <a asp-controller="Chat" asp-action="Index"
       class="text-white text-decoration-none">
        <i class="bi bi-arrow-left fs-5"></i>
    </a>

    @if (!string.IsNullOrEmpty(Model.FriendAvatar))
    {
        <img src="@Model.FriendAvatar"
             class="rounded-circle"
             style="width:40px;height:40px;object-fit:cover;" />
    }
    else
    {
        <div class="rounded-circle bg-white text-primary d-flex
                    align-items-center justify-content-center fw-bold"
             style="width:40px;height:40px;">
            @Model.FriendName[0]
        </div>
    }

    <div class="flex-grow-1">     
        <div class="fw-bold">@Model.FriendName</div>
        <small id="statusText" class="opacity-75">
            <span id="onlineStatus"></span>
        </small>
    </div>

    
    <div class="d-flex gap-2">
        <button class="btn btn-outline-light btn-sm"
                onclick="CallManager.startPrivateCall('@Model.FriendId', false)"
                title="Audio Call">
            <i class="bi bi-telephone-fill"></i>
        </button>
        <button class="btn btn-outline-light btn-sm"
                onclick="CallManager.startPrivateCall('@Model.FriendId', true)"
                title="Video Call">
            <i class="bi bi-camera-video-fill"></i>
        </button>
    </div>
</div>
            <!-- Messages Area -->
            <div class="card-body overflow-auto p-3 flex-grow-1" id="messagesArea">
                @foreach (var msg in Model.Messages)
                {
                    var isMine = msg.SenderId == Model.CurrentUserId;
                    <div class="d-flex mb-3 @(isMine ? "justify-content-end" : "justify-content-start")"
                         id="msg-@msg.Id">
                        <div class="@(isMine ? "bg-primary text-white" : "bg-light text-dark")
                                    rounded-3 px-3 py-2"
                             style="max-width:70%;">
                            <div>@msg.Content</div>
                            <div class="d-flex gap-1 justify-content-end mt-1">
                                <small class="opacity-75" style="font-size:0.7rem;">
                                    @msg.SentAt.ToString("hh:mm tt")
                                </small>
                                @if (isMine)
                                {
                                    <small class="opacity-75" style="font-size:0.7rem;">
                                        @(msg.IsRead ? "✓✓" : "✓")
                                    </small>
                                }
                            </div>
                        </div>
                    </div>
                }

                <!-- Typing Indicator -->
                <div id="typingIndicator" class="d-none mb-2">
                    <div class="bg-light rounded-3 px-3 py-2 d-inline-block">
                        <span class="text-muted small">
                            @Model.FriendName is typing
                            <span class="typing-dots">
                                <span>.</span><span>.</span><span>.</span>
                            </span>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Message Input -->
            <div class="card-footer p-2">
                <div class="input-group">
                    <input type="text"
                           id="messageInput"
                           class="form-control"
                           placeholder="Type a message..."
                           autocomplete="off" />
                    <button class="btn btn-primary" id="sendBtn">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CSS -->
<style>
    .typing-dots span {
        animation: blink 1.4s infinite;
        animation-fill-mode: both;
    }
    .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes blink {
        0% { opacity: 0.2; }
        20% { opacity: 1; }
        100% { opacity: 0.2; }
    }
</style>

@section Scripts {
<script>
    const currentUserId = "@Model.CurrentUserId";
    const friendId      = "@Model.FriendId";
    const friendName    = "@Model.FriendName";

    const messagesArea      = document.getElementById("messagesArea");
    const messageInput      = document.getElementById("messageInput");
    const sendBtn           = document.getElementById("sendBtn");
    const typingIndicator   = document.getElementById("typingIndicator");
    const onlineStatus      = document.getElementById("onlineStatus");

    // ─── SignalR Connection ──────────────────────────────────────
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .withAutomaticReconnect()
        .build();

    // ─── Receive Message ─────────────────────────────────────────
    connection.on("ReceiveMessage", (msg) => {
        // Only show messages between current user and friend
        if ((msg.senderId === currentUserId && "@Model.FriendId" === friendId) ||
            (msg.senderId === friendId)) {
            appendMessage(msg);
            scrollToBottom();

            // Ekhane achi tai mark as read
            if (msg.senderId === friendId) {
                connection.invoke("MarkAsRead", friendId);
            }
        }
    });

    // ─── Typing Indicators ───────────────────────────────────────
    let typingTimer;
    connection.on("UserTyping", (userId, name) => {
        if (userId === friendId) {
            typingIndicator.classList.remove("d-none");
            scrollToBottom();
        }
    });

    connection.on("UserStopTyping", (userId) => {
        if (userId === friendId) {
            typingIndicator.classList.add("d-none");
        }
    });

    // ─── Online Status ───────────────────────────────────────────
    connection.on("UserOnline", (userId) => {
        if (userId === friendId)
            onlineStatus.innerHTML = '🟢 Online';
    });

    connection.on("UserOffline", (userId) => {
        if (userId === friendId)
            onlineStatus.innerHTML = '⚫ Offline';
    });

    // ─── Read Receipts ───────────────────────────────────────────
    connection.on("MessagesRead", (byUserId) => {
        if (byUserId === friendId) {
            // All single-tick → double-tick
            document.querySelectorAll(".read-receipt").forEach(el => {
                el.textContent = "✓✓";
            });
        }
    });

    // ─── Start Connection ────────────────────────────────────────
    connection.start().then(async () => {
        // Mark as read on open
        await connection.invoke("MarkAsRead", friendId);

        // Check if friend is online
        const onlineUsers = await connection.invoke("GetOnlineUsers");
        onlineStatus.innerHTML = onlineUsers.includes(friendId)
            ? '🟢 Online' : '⚫ Offline';
    });

    // ─── Send Message ─────────────────────────────────────────────
    function sendMessage() {
        const content = messageInput.value.trim();
        if (!content) return;
        connection.invoke("SendMessage", friendId, content);
        messageInput.value = "";
        connection.invoke("StopTyping", friendId);
    }

    sendBtn.addEventListener("click", sendMessage);
    messageInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter" && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    // ─── Typing Detection ─────────────────────────────────────────
    messageInput.addEventListener("input", () => {
        connection.invoke("Typing", friendId);
        clearTimeout(typingTimer);
        typingTimer = setTimeout(() => {
            connection.invoke("StopTyping", friendId);
        }, 1500);
    });

    // ─── Append Message to DOM ────────────────────────────────────
    function appendMessage(msg) {
        const isMine = msg.senderId === currentUserId;
        const div = document.createElement("div");
        div.className = `d-flex mb-3 ${isMine ? "justify-content-end" : "justify-content-start"}`;
        div.id = `msg-${msg.id}`;
        div.innerHTML = `
            <div class="${isMine ? "bg-primary text-white" : "bg-light text-dark"}
                        rounded-3 px-3 py-2" style="max-width:70%;">
                <div>${escapeHtml(msg.content)}</div>
                <div class="d-flex gap-1 justify-content-end mt-1">
                    <small class="opacity-75" style="font-size:0.7rem;">${msg.sentAt}</small>
                    ${isMine
                        ? `<small class="opacity-75 read-receipt" style="font-size:0.7rem;">✓</small>`
                        : ""}
                </div>
            </div>`;
        // Insert before typing indicator
        messagesArea.insertBefore(div, typingIndicator);
    }

    // ─── XSS Protection ──────────────────────────────────────────
    function escapeHtml(text) {
        const div = document.createElement("div");
        div.appendChild(document.createTextNode(text));
        return div.innerHTML;
    }

    // ─── Auto Scroll ──────────────────────────────────────────────
    function scrollToBottom() {
        messagesArea.scrollTop = messagesArea.scrollHeight;
    }

    scrollToBottom();
</script>
}