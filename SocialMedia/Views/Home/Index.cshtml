@model List<SocialMedia.ViewModels.UserCardViewModel>
@{
    ViewData["Title"] = "Home";
}

<h4 class="fw-bold mb-4"><i class="bi bi-people"></i> People You May Know</h4>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-person-x" style="font-size:3rem"></i>
        <p class="mt-2">No other users yet.</p>
    </div>
}

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
    @foreach (var user in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm text-center">
                <div class="card-body">
                    <a asp-controller="Account" asp-action="Profile"
                           asp-route-id="@user.Id" class="text-decoration-none">
                        @if (!string.IsNullOrEmpty(user.ProfilePicture))
                        {
                            <img src="@user.ProfilePicture"
                                 class="rounded-circle mb-3"
                                 style="width:80px;height:80px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-primary text-white d-flex
                                align-items-center justify-content-center mx-auto mb-3"
                                 style="width:80px;height:80px;font-size:2rem;">
                                @user.FullName[0]
                            </div>
                        }
                        <h6 class="fw-bold text-dark">@user.FullName</h6>
                    </a>
                    <p class="text-muted small mb-3">
                        @(string.IsNullOrEmpty(user.Bio) ? "No bio yet" :
                          (user.Bio.Length > 50 ? user.Bio[..50] + "..." : user.Bio))
                    </p>

                    @* Friend Action Buttons *@
                    @if (user.IsFriend)
                    {
                        <div class="d-flex gap-2 justify-content-center">
                            <a asp-controller="Chat" asp-action="Open"
                                   asp-route-userId="@user.Id"
                                   class="btn btn-success btn-sm">
                                <i class="bi bi-chat-fill"></i> Message
                            </a>
                            <form asp-controller="Friend" asp-action="Unfriend" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="friendId" value="@user.Id" />
                                <button class="btn btn-outline-danger btn-sm">Unfriend</button>
                            </form>
                        </div>
                    }
                    else if (user.HasPendingRequestSent)
                    {
                        <form asp-controller="Friend" asp-action="CancelRequest" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="requestId" value="@user.FriendRequestId" />
                            <button class="btn btn-secondary btn-sm w-100">
                                <i class="bi bi-x-circle"></i> Cancel Request
                            </button>
                        </form>
                    }
                    else if (user.HasPendingRequestReceived)
                    {
                        <div class="d-flex gap-2 justify-content-center">
                            <form asp-controller="Friend" asp-action="AcceptRequest" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="requestId" value="@user.FriendRequestId" />
                                <button class="btn btn-primary btn-sm">
                                    <i class="bi bi-check-circle"></i> Accept
                                </button>
                            </form>
                            <form asp-controller="Friend" asp-action="RejectRequest" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="requestId" value="@user.FriendRequestId" />
                                <button class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-x"></i> Reject
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <form asp-controller="Friend" asp-action="SendRequest" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="receiverId" value="@user.Id" />
                            <button class="btn btn-primary btn-sm w-100">
                                <i class="bi bi-person-plus"></i> Add Friend
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</div>