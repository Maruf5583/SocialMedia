@using SocialMedia.ViewModels
@using SocialMedia.Models

@model SocialMedia.ViewModels.PostViewModel

@{
    var reactionEmojis = new Dictionary<string, string>
    {
        {"Like","👍"}, {"Love","❤️"}, {"Haha","😂"},
        {"Wow","😮"}, {"Sad","😢"}, {"Angry","😡"}
    };

    string TimeAgo(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 1)  return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24)   return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7)     return $"{(int)diff.TotalDays}d ago";
        return dt.ToString("MMM dd, yyyy");
    }
    
    // Check if content is long
    bool isLongContent = !string.IsNullOrEmpty(Model.Content) && 
                         (Model.Content.Length > 150 || Model.Content.Split('\n').Length > 3);
    
    // Get preview text (first 150 chars or first 3 lines)
    string previewContent = "";
    if (!string.IsNullOrEmpty(Model.Content))
    {
        if (Model.Content.Length > 150)
        {
            previewContent = Model.Content.Substring(0, 150) + "...";
        }
        else
        {
            var lines = Model.Content.Split('\n');
            if (lines.Length > 3)
            {
                previewContent = string.Join("\n", lines.Take(3)) + "...";
            }
            else
            {
                previewContent = Model.Content;
            }
        }
    }
}

<div class="card shadow-sm mb-3" id="post-@Model.Id"
     style="border-radius:12px;border:none;">
    <div class="card-body p-3">

        <!-- ── Post Header ─────────────────────────────────── -->
        <div class="d-flex align-items-center gap-2 mb-2">
            <a asp-controller="Account" asp-action="Profile"
               asp-route-id="@Model.UserId">
                @if (!string.IsNullOrEmpty(Model.UserAvatar))
                {
                    <img src="@Model.UserAvatar" class="rounded-circle"
                         style="width:42px;height:42px;object-fit:cover;" />
                }
                else
                {
                    <div class="rounded-circle bg-primary text-white d-flex
                                align-items-center justify-content-center fw-bold"
                         style="width:42px;height:42px;">
                        @Model.UserName[0]
                    </div>
                }
            </a>
            <div class="flex-grow-1">
                <a asp-controller="Account" asp-action="Profile"
                   asp-route-id="@Model.UserId"
                   class="fw-bold text-dark text-decoration-none">
                    @Model.UserName
                </a>
                @if (Model.IsShared)
                {
                    <span class="text-muted small"> shared a post</span>
                }
                <div class="text-muted" style="font-size:0.78rem;">
                    @TimeAgo(Model.CreatedAt)
                    @if (Model.IsEdited)
                    {
                        <span class="ms-1">· <i>Edited</i></span>
                    }
                </div>
            </div>

            <!-- Options dropdown (own post) -->
            @if (Model.IsOwnPost)
            {
                <div class="dropdown">
                    <button class="btn btn-light btn-sm rounded-circle"
                            data-bs-toggle="dropdown">
                        <i class="bi bi-three-dots"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                        <li>
                            <button class="dropdown-item"
                                    onclick="openEditModal(
                                        @Model.Id,
                                        `@Html.Raw(Model.Content?.Replace("`","\\`") ?? "")`,
                                        `@(Model.ImagePath ?? "")`)">
                                <i class="bi bi-pencil text-primary"></i> Edit Post
                            </button>
                        </li>
                        <li>
                            <form asp-controller="Post" asp-action="Delete"
                                  method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button class="dropdown-item text-danger"
                                        onclick="return confirm('Delete this post?')">
                                    <i class="bi bi-trash"></i> Delete Post
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
        </div>

        <!-- ── Post Content with See More/Less ──────────────────────── -->
        @if (!string.IsNullOrEmpty(Model.Content))
        {
            if (isLongContent)
            {
                <!-- Preview Content -->
                <div id="post-preview-@Model.Id" class="post-content-preview">
                    <p class="mb-0" style="white-space:pre-wrap;">@Html.Raw(previewContent)</p>
                </div>
                
                <!-- Full Content (hidden initially) -->
                <div id="post-full-@Model.Id" class="post-content-full d-none">
                    <p class="mb-0" style="white-space:pre-wrap;">@Html.Raw(Model.Content)</p>
                </div>
                
                <!-- See More / See Less Button -->
                <button class="btn btn-link btn-sm p-0 mt-1 text-primary" 
                        onclick="togglePostContent(@Model.Id)"
                        style="text-decoration:none;font-size:0.8rem;">
                    <i class="bi bi-chevron-down"></i> See more
                </button>
            }
            else
            {
                <p class="mb-2" style="white-space:pre-wrap;">@Model.Content</p>
            }
        }

        <!-- ── Post Image ──────────────────────────────────────────── -->
        @if (!string.IsNullOrEmpty(Model.ImagePath) && !Model.IsShared)
        {
            <div class="mb-2">
                <img src="@Model.ImagePath"
                     class="img-fluid w-100"
                     style="border-radius:10px;max-height:500px;object-fit:cover;cursor:pointer;"
                     onclick="openImageViewer('@Model.ImagePath')" />
            </div>
        }

        <!-- ── Shared Original Post ────────────────────────── -->
        @if (Model.IsShared && Model.OriginalPost != null)
        {
            <div class="border rounded p-3 bg-light mb-2" style="border-radius:10px!important;">
                <div class="d-flex align-items-center gap-2 mb-2">
                    @if (!string.IsNullOrEmpty(Model.OriginalPost.UserAvatar))
                    {
                        <img src="@Model.OriginalPost.UserAvatar" class="rounded-circle"
                             style="width:32px;height:32px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-secondary text-white d-flex
                                    align-items-center justify-content-center"
                             style="width:32px;height:32px;font-size:0.8rem;">
                            @Model.OriginalPost.UserName[0]
                        </div>
                    }
                    <div>
                        <a asp-controller="Account" asp-action="Profile"
                           asp-route-id="@Model.OriginalPost.UserId"
                           class="fw-bold small text-dark text-decoration-none">
                            @Model.OriginalPost.UserName
                        </a>
                        <div class="text-muted" style="font-size:0.72rem;">
                            @TimeAgo(Model.OriginalPost.CreatedAt)
                        </div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.OriginalPost.Content))
                {
                    <p class="small mb-2">@Model.OriginalPost.Content</p>
                }
                @if (!string.IsNullOrEmpty(Model.OriginalPost.ImagePath))
                {
                    <img src="@Model.OriginalPost.ImagePath"
                         class="img-fluid w-100"
                         style="border-radius:8px;max-height:300px;object-fit:cover;" />
                }
            </div>
        }

        <!-- ── Reaction Summary ────────────────────────────── -->
        <div class="d-flex justify-content-between text-muted small py-1
                    border-bottom mb-1">
            <span>
                <span id="reaction-summary-@Model.Id">
                    @foreach (var r in Model.ReactionCounts)
                    {
                        <span>@(reactionEmojis.GetValueOrDefault(r.Key, ""))</span>
                    }
                </span>
                <span id="reaction-total-@Model.Id">
                    @(Model.TotalReactions > 0 ? Model.TotalReactions.ToString() : "")
                </span>
            </span>
            <span>
                @if (Model.CommentCount > 0)
                {
                    <span class="me-2">
                        <i class="bi bi-chat"></i> @Model.CommentCount
                    </span>
                }
                @if (Model.ShareCount > 0)
                {
                    <span>@Model.ShareCount share@(Model.ShareCount > 1 ? "s" : "")</span>
                }
            </span>
        </div>

        <!-- ── Action Buttons ──────────────────────────────── -->
        <div class="d-flex gap-1 pt-1">

            <!-- React Button with Popup -->
            <div class="position-relative flex-fill">
                <button class="btn btn-light btn-sm w-100 reaction-btn-@Model.Id
                               @(Model.MyReaction.HasValue ? "active-reaction" : "")"
                        id="react-@(Model.Id)-@(Model.MyReaction?.ToString() ?? "none")"
                        onmouseenter="showReactions(@Model.Id)"
                        onmouseleave="scheduleHideReactions(@Model.Id)"
                        onclick="reactToPost(@Model.Id, 'Like')">
                    @if (Model.MyReaction.HasValue)
                    {
                        <span>
                            @reactionEmojis.GetValueOrDefault(Model.MyReaction.ToString()!, "👍")
                            @Model.MyReaction.ToString()
                        </span>
                    }
                    else
                    {
                        <span><i class="bi bi-hand-thumbs-up"></i> Like</span>
                    }
                </button>

                <!-- Reaction Popup -->
                <div class="reaction-popup d-none shadow rounded-pill bg-white px-2 py-1"
                     id="reaction-popup-@Model.Id"
                     onmouseenter="cancelHideReactions(@Model.Id)"
                     onmouseleave="scheduleHideReactions(@Model.Id)"
                     style="position:absolute;bottom:110%;left:0;z-index:100;
                            white-space:nowrap;border:1px solid #eee;">
                    @foreach (var emoji in reactionEmojis)
                    {
                        <button class="btn btn-sm p-1 reaction-btn-@Model.Id"
                                id="react-@(Model.Id)-@emoji.Key"
                                onclick="reactToPost(@Model.Id, '@emoji.Key');
                                         hideReactions(@Model.Id)"
                                title="@emoji.Key"
                                style="font-size:1.4rem;transition:transform 0.15s;"
                                onmouseenter="this.style.transform='scale(1.3)'"
                                onmouseleave="this.style.transform='scale(1)'">
                            @emoji.Value
                        </button>
                    }
                </div>
            </div>

            <!-- Comment Button -->
            <button class="btn btn-light btn-sm flex-fill" 
                    onclick="toggleComments(@Model.Id)">
                <i class="bi bi-chat"></i> Comment
            </button>

            <!-- Share Button -->
            <button class="btn btn-light btn-sm flex-fill"
                    onclick="openShareModal(
                        @(Model.OriginalPostId ?? Model.Id),
                        '@Html.Raw(Model.UserName)',
                        `@Html.Raw((Model.OriginalPost?.Content ?? Model.Content)
                            ?.Replace("`","\\`")
                            ?.Replace("'","\\'") ?? "")`,
                        '@(Model.OriginalPost?.ImagePath ?? Model.ImagePath ?? "")')">
                <i class="bi bi-share"></i> Share
            </button>
        </div>

        <!-- ── Comments Section ──────────────────────────────── -->
        <div id="commentsSection-@Model.Id" class="mt-3 d-none">
            <div class="comment-form mb-3">
                <div class="d-flex gap-2">
                    @if (!string.IsNullOrEmpty(Model.CurrentUserAvatar))
                    {
                        <img src="@Model.CurrentUserAvatar" class="rounded-circle"
                             style="width:32px;height:32px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-primary text-white d-flex
                                    align-items-center justify-content-center"
                             style="width:32px;height:32px;font-size:0.8rem;">
                            @(Model.CurrentUserName?.FirstOrDefault() ?? 'U')
                        </div>
                    }
                    <div class="flex-grow-1">
                        <textarea id="commentText-@Model.Id" 
                                  class="form-control form-control-sm" 
                                  rows="2" 
                                  placeholder="Write a comment..."
                                  style="border-radius:20px;resize:none;"></textarea>
                        <div class="mt-2 text-end">
                            <button class="btn btn-secondary btn-sm" 
                                    onclick="cancelComment(@Model.Id)">
                                Cancel
                            </button>
                            <button class="btn btn-primary btn-sm" 
                                    onclick="addComment(@Model.Id)">
                                <i class="bi bi-send"></i> Post
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <div id="commentsList-@Model.Id" class="comments-list">
                <div class="text-center text-muted small py-2">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span class="ms-2">Loading comments...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .active-reaction {
        color: #0d6efd !important;
        font-weight: 600;
    }
    .reaction-popup { animation: fadeIn 0.15s ease; }
    @@keyframes fadeIn {
        from { opacity:0; transform:translateY(4px); }
        to   { opacity:1; transform:translateY(0); }
    }
    
    .comment-avatar {
        width: 28px;
        height: 28px;
        object-fit: cover;
    }
    .comment-bubble {
        background-color: #f0f2f5;
        border-radius: 18px;
        padding: 8px 12px;
        display: inline-block;
        max-width: 100%;
    }
    .comment-text {
        font-size: 0.875rem;
        word-break: break-word;
    }
    .comment-time {
        font-size: 0.7rem;
    }
    .reply-btn {
        font-size: 0.7rem;
    }
    .replies-container {
        margin-left: 38px;
    }
</style>

<!-- JavaScript for See More/Less and Image Viewer -->
<script>
    // Toggle post content (See More / See Less)
    function togglePostContent(postId) {
        const previewDiv = document.getElementById(`post-preview-${postId}`);
        const fullDiv = document.getElementById(`post-full-${postId}`);
        const btn = event.currentTarget;
        
        if (previewDiv && fullDiv && btn) {
            if (previewDiv.classList.contains('d-none')) {
                // Currently showing full, switch to preview
                previewDiv.classList.remove('d-none');
                fullDiv.classList.add('d-none');
                btn.innerHTML = '<i class="bi bi-chevron-down"></i> See more';
            } else {
                // Currently showing preview, switch to full
                previewDiv.classList.add('d-none');
                fullDiv.classList.remove('d-none');
                btn.innerHTML = '<i class="bi bi-chevron-up"></i> See less';
            }
        }
    }
    
    // Open image viewer
    function openImageViewer(imageUrl) {
        // Create modal for image viewing
        const modalHtml = `
            <div class="modal fade" id="imageViewerModal" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content bg-transparent border-0">
                        <div class="modal-body text-center">
                            <button type="button" class="btn-close btn-close-white mb-2" data-bs-dismiss="modal"></button>
                            <img src="${imageUrl}" class="img-fluid rounded" style="max-height:80vh;max-width:100%;" />
                        </div>
                    </div>
                </div>
            </div>
        `;
        
        // Remove existing modal if any
        const existingModal = document.getElementById('imageViewerModal');
        if (existingModal) {
            existingModal.remove();
        }
        
        // Add modal to body
        document.body.insertAdjacentHTML('beforeend', modalHtml);
        
        // Show modal
        const modal = new bootstrap.Modal(document.getElementById('imageViewerModal'));
        modal.show();
        
        // Remove modal after hidden
        document.getElementById('imageViewerModal').addEventListener('hidden.bs.modal', function() {
            this.remove();
        });
    }
</script>