<!-- ══════════════════════════════════════
     INCOMING CALL MODAL
══════════════════════════════════════ -->
<div class="modal fade" id="incomingCallModal" tabindex="-1"
     data-bs-backdrop="static">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;">
            <div class="modal-body text-center p-4">
                <div id="incomingCallerAvatar" class="mb-3"></div>
                <p id="incomingCallType"
                   class="text-muted small mb-1"></p>
                <h5 id="incomingCallerName"
                    class="fw-bold mb-4"></h5>
                <div class="d-flex justify-content-center gap-4">
                    <div class="text-center">
                        <button id="rejectCallBtn"
                                class="btn btn-danger rounded-circle"
                                style="width:56px;height:56px;font-size:1.3rem;">
                            <i class="bi bi-telephone-x-fill"></i>
                        </button>
                        <div class="small text-muted mt-1">Decline</div>
                    </div>
                    <div class="text-center">
                        <button id="acceptCallBtn"
                                class="btn btn-success rounded-circle"
                                style="width:56px;height:56px;font-size:1.3rem;">
                            <i class="bi bi-telephone-fill"></i>
                        </button>
                        <div class="small text-muted mt-1">Accept</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════
     CALLING MODAL (Outgoing)
══════════════════════════════════════ -->
<div class="modal fade" id="callingModal" tabindex="-1"
     data-bs-backdrop="static">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;">
            <div class="modal-body text-center p-4">
                <div class="spinner-border text-primary mb-3"></div>
                <p class="fw-semibold">Calling...</p>
                <button class="btn btn-danger mt-2"
                        onclick="CallManager.cancelCall()">
                    <i class="bi bi-telephone-x-fill"></i> Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════
     ACTIVE CALL MODAL
══════════════════════════════════════ -->
<div class="modal fade" id="callModal" tabindex="-1"
     data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-dark text-white"
             style="border-radius:16px;min-height:500px;">

            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold" id="callModalLabel">
                    Video Call
                </h6>
                <span class="badge bg-success ms-2" id="callDuration">
                    00:00
                </span>
            </div>

            <div class="modal-body p-3">

                <!-- Audio Call UI (hidden for video) -->
                <div id="audioCallUI" class="d-none text-center py-5">
                    <i class="bi bi-telephone-fill text-success"
                       style="font-size:4rem;"></i>
                    <p class="mt-3 fw-semibold fs-5">Call Connected</p>
                </div>

                <!-- Remote Videos -->
                <div id="remoteVideosArea"
                     class="d-flex flex-wrap gap-2 justify-content-center mb-2"
                     style="min-height:300px;">
                    <!-- Remote video streams যাবে এখানে -->
                </div>

                <!-- Local Video (small, corner) -->
                <div style="position:relative;">
                    <video id="localVideo" autoplay muted playsinline
                           class="rounded"
                           style="position:absolute;bottom:0;right:0;
                        width:140px;height:100px;
                        object-fit:cover;z-index:10;
                        border:2px solid #fff;">
                    </video>
                </div>
            </div>

            <!-- Call Controls -->
            <div class="modal-footer border-0 justify-content-center pb-4 gap-3">

                <!-- Mute -->
                <div class="text-center">
                    <button id="muteBtn"
                            class="btn btn-secondary rounded-circle"
                            style="width:52px;height:52px;font-size:1.2rem;"
                            onclick="CallManager.toggleAudio()">
                        <i class="bi bi-mic-fill"></i>
                    </button>
                    <div class="small text-muted mt-1">Mute</div>
                </div>

                <!-- End Call -->
                <div class="text-center">
                    <button class="btn btn-danger rounded-circle"
                            style="width:60px;height:60px;font-size:1.4rem;"
                            onclick="CallManager.hangUp()">
                        <i class="bi bi-telephone-x-fill"></i>
                    </button>
                    <div class="small text-muted mt-1">End</div>
                </div>

                <!-- Camera -->
                <div class="text-center" id="cameraBtnContainer">
                    <button id="cameraBtn"
                            class="btn btn-secondary rounded-circle"
                            style="width:52px;height:52px;font-size:1.2rem;"
                            onclick="CallManager.toggleVideo()">
                        <i class="bi bi-camera-video-fill"></i>
                    </button>
                    <div class="small text-muted mt-1">Camera</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════
     TOAST NOTIFICATION
══════════════════════════════════════ -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999">
    <div id="callToast" class="toast align-items-center border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body fw-semibold"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto"
                    data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════
     CALL STYLES
══════════════════════════════════════ -->
<style>
    .remote-participant {
        position: relative;
        min-width: 200px;
        min-height: 150px;
        background: #2a2a2a;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 1;
    }

    .remote-video {
        width: 100%;
        height: 100%;
        border-radius: 12px;
        object-fit: cover;
    }

    .participant-placeholder {
        text-align: center;
        color: white;
    }

    #callModal .modal-content {
        background: linear-gradient(135deg, #1a1a2e, #16213e);
    }
</style>